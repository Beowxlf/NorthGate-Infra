# ScrambleIQ API runtime
PORT=3000
WEB_ORIGIN=http://localhost
API_AUTH_TOKEN=CHANGE_ME
DATABASE_URL=postgresql://scrambleiq:CHANGE_ME@scrambleiq-db:5432/scrambleiq

# ScrambleIQ web build-time settings (embedded in frontend bundle)
VITE_API_BASE_URL=/api
VITE_API_AUTH_TOKEN=CHANGE_ME

# PostgreSQL container
POSTGRES_DB=scrambleiq
POSTGRES_USER=scrambleiq
POSTGRES_PASSWORD=CHANGE_ME

# Source control for deterministic build
SCRAMBLEIQ_REPO_URL=https://github.com/Beowxlf/ScrambleIQ.git
SCRAMBLEIQ_REPO_REF=ca190cc12af74ddb1967bb2148da41cfa24b5b67
