# ScrambleIQ runtime configuration
APP_ENV=production
APP_PORT=8080
APP_BIND=0.0.0.0

# Data dependencies
DB_HOST=scrambleiq-db
DB_PORT=5432
DB_NAME=scrambleiq
DB_USER=scrambleiq
DB_PASSWORD=CHANGE_ME

# Authentication / identity bridge
AUTH_MODE=UNKNOWN
AUTH_ISSUER_URL=UNKNOWN
AUTH_CLIENT_ID=UNKNOWN
AUTH_CLIENT_SECRET=CHANGE_ME

# Logging controls
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REQUESTS=true
LOG_AUTH_EVENTS=true
